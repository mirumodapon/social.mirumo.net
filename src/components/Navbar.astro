---
const currentPath = Astro.url.pathname;
---

<aside class="sidebar-left">
  <div class="logo"></div>

  <nav>
    <ul class="nav-items">
      <li class="nav-item" class:list={[{ active: currentPath === '/' }]}>
        <a href="/">
          <span class="nav-icon"><i class="ti ti-home"></i></span>
          <span class="nav-text">首頁</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/rss.xml">
          <span class="nav-icon"><i class="ti ti-rss"></i></span>
          <span class="nav-text">RSS</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="https://buymeacoffee.com/mirumodapon">
          <span class="nav-icon"><i class="ti ti-coffee"></i></span>
          <span class="nav-text">Buy Me A Coffee</span>
        </a>
      </li>
      <li class="nav-item">
        <button id="theme-toggle" class="theme-toggle-btn">
          <span class="nav-icon" id="theme-icon">
            <i class="ti ti-moon"></i>
          </span>
          <span class="nav-text" id="theme-text">深色模式</span>
        </button>
      </li>
    </ul>
  </nav>
</aside>

<style>
  .theme-toggle-btn {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 16px;
    border-radius: 9999px;
    font-size: 20px;
    font-weight: 400;
    transition: background 0.2s;
    width: 100%;
    text-align: left;
    color: var(--text-primary);
    background: none;
    border: none;
    cursor: pointer;
  }

  .theme-toggle-btn:hover {
    background: var(--bg-hover);
  }

  .theme-toggle-btn .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    font-size: 24px;
  }
</style>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const themeIcon = document.getElementById('theme-icon');
  const themeText = document.getElementById('theme-text');

  const updateUI = (theme: string) => {
    if (themeIcon && themeText) {
      if (theme === 'light') {
        themeIcon.innerHTML = '<i class="ti ti-sun"></i>';
        themeText.innerText = '淺色模式';
      } else {
        themeIcon.innerHTML = '<i class="ti ti-moon"></i>';
        themeText.innerText = '深色模式';
      }
    }
  };

  const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
  updateUI(currentTheme);

  themeToggle?.addEventListener('click', () => {
    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    const newTheme = isLight ? 'dark' : 'light';
    
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    updateUI(newTheme);
  });
</script>
