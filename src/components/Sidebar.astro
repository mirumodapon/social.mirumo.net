---
import { getCollection } from 'astro:content';
import { SIDEBAR_TAG_COUNT } from '../config/site';

const posts = await getCollection('posts');
const tagCounts = new Map<string, number>();

posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});

const trends = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, SIDEBAR_TAG_COUNT)
  .map(([tag, count]) => ({
    tag,
    label: `#${tag}`,
    count: `${count} 則貼文`,
    href: `/tag/${encodeURIComponent(tag)}`,
  }));
---

<aside class="sidebar-right">
  <div class="search-box">
    <span class="search-icon"><i class="ti ti-search"></i></span>
    <input type="text" placeholder="搜尋" />
  </div>

  <div class="widget">
    <h2 class="widget-title">熱門標籤</h2>
    {trends.length > 0 ? (
      trends.map((trend) => (
        <a href={trend.href} class="widget-item">
          <div class="trend-name">{trend.label}</div>
          <div class="trend-count">{trend.count}</div>
        </a>
      ))
    ) : (
      <div class="widget-item">目前尚無標籤</div>
    )}
    <a href="/tags" class="widget-show-more">顯示更多</a>
  </div>
</aside>