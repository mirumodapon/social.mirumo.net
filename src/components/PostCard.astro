---
import { getCollection } from 'astro:content';
import PostAbstract from './PostAbstract.astro';

interface Props {
  id: string;
  author: string;
  handle: string;
  avatar: string;
  abstract: string;
  date: string;
  tags?: string[];
  hasContent: boolean;
}

const { id, author, handle, avatar: postAvatar, abstract: abstractText, date, tags, hasContent } = Astro.props;

const users = await getCollection('users');
const postUser = users.find((u) => u.data.handle === handle);
const hasUserProfile = !!postUser;
const avatar = (postAvatar === 'auto' && postUser) ? postUser.data.avatar : postAvatar;

const avatarColors = ['#1d9bf0', '#f91880', '#00ba7c', '#ffd400', '#7856ff', '#f97316'];
const colorIndex = author.charCodeAt(0) % avatarColors.length;
const avatarColor = avatarColors[colorIndex];
const avatarLetter = author.charAt(0).toUpperCase();

const Tag = 'div';
---

<Tag 
  onclick={hasContent ? `location.href='/post/${id}'` : undefined} 
  class:list={['post-card', { clickable: hasContent }]}
>
  {hasUserProfile ? (
    <a href={`/user/${handle}`} class="post-avatar" onclick="event.stopPropagation();">
      {avatar.startsWith('http') || avatar.startsWith('/') ? (
        <img src={avatar} alt={author} />
      ) : (
        <div class="avatar-placeholder" style={`background:${avatarColor}`}>
          {avatar === 'auto' ? avatarLetter : avatar}
        </div>
      )}
    </a>
  ) : (
    <div class="post-avatar">
      {avatar.startsWith('http') || avatar.startsWith('/') ? (
        <img src={avatar} alt={author} />
      ) : (
        <div class="avatar-placeholder" style={`background:${avatarColor}`}>
          {avatar === 'auto' ? avatarLetter : avatar}
        </div>
      )}
    </div>
  )}
  <div class="post-body">
    <div class="post-header">
      {hasUserProfile ? (
        <>
          <a href={`/user/${handle}`} class="post-author" onclick="event.stopPropagation();">{author}</a>
          <a href={`/user/${handle}`} class="post-handle" onclick="event.stopPropagation();">@{handle}</a>
        </>
      ) : (
        <>
          <span class="post-author">{author}</span>
          <span class="post-handle">@{handle}</span>
        </>
      )}
      <time class="post-date" datetime={date}></time>
    </div>
    <PostAbstract
      content={abstractText}
      wrapperClass="post-text"
      stopLinkPropagation={hasContent}
    />
    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => (
          <a 
            href={`/tag/${encodeURIComponent(tag)}`} 
            class="tag"
            onclick="event.stopPropagation();"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}
  </div>
</Tag>

<script>
  function formatDate(dateStr: string) {
    const d = new Date(dateStr);
    const now = new Date();
    const diff = now.getTime() - d.getTime();
    const hours = Math.floor(diff / (1000 * 60 * 60));
    if (hours < 1) return '剛剛';
    if (hours < 24) return `${hours}小時`;
    const days = Math.floor(hours / 24);
    if (days < 7) return `${days}天`;
    return `${d.getMonth() + 1}月${d.getDate()}日`;
  }

  document.querySelectorAll<HTMLTimeElement>('time.post-date[datetime]').forEach((el) => {
    el.textContent = formatDate(el.getAttribute('datetime')!);
  });
</script>

<style>
  .tag:hover {
    text-decoration: underline;
  }
  .post-avatar {
    display: block;
    flex-shrink: 0;
    border-radius: 50%;
    transition: opacity 0.2s;
  }
  a.post-avatar:hover {
    opacity: 0.85;
  }
  a.post-author:hover {
    text-decoration: underline;
  }
  a.post-handle:hover {
    text-decoration: underline;
  }
</style>
