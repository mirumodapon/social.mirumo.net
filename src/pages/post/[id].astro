---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import PostAbstract from '../../components/PostAbstract.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  // Only generate detail pages for posts that have body content
  return posts
    .filter((post) => !!post.body?.trim())
    .map((post) => ({
      params: { id: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection('posts');
const users = await getCollection('users');
const postUser = users.find((u) => u.data.handle === post.data.handle);
const displayAvatar = (post.data.avatar === 'auto' && postUser) ? postUser.data.avatar : post.data.avatar;

function normalizeSeries(series) {
  if (!series) return null;
  return typeof series === 'string'
    ? { id: series.toLowerCase().replace(/\s+/g, '-'), name: series }
    : series;
}

const currentSeries = normalizeSeries(post.data.series);
const seriesPosts = currentSeries
  ? allPosts
      .filter((item) => {
        const itemSeries = normalizeSeries(item.data.series);
        return itemSeries?.id === currentSeries.id && item.id !== post.id;
      })
      .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  : [];

const avatarColors = ['#1d9bf0', '#f91880', '#00ba7c', '#ffd400', '#7856ff', '#f97316'];
const colorIndex = post.data.author.charCodeAt(0) % avatarColors.length;
const avatarColor = avatarColors[colorIndex];
const avatarLetter = post.data.author.charAt(0).toUpperCase();

---

<BaseLayout title={`${post.data.author} 的貼文 / Social`}>
  <div class="page-header">
    <div class="back-btn">
      <a href="/" class="back-arrow" onclick="history.length > 1 ? history.back() : null; return false;">
        <i class="ti ti-arrow-left"></i>
      </a>
      <h1>貼文</h1>
    </div>
  </div>

  <article class="post-detail">
    <div class="post-header">
      <a href={`/user/${post.data.handle}`} class="post-avatar">
        {displayAvatar.startsWith('http') || displayAvatar.startsWith('/') ? (
          <img src={displayAvatar} alt={post.data.author} />
        ) : (
          <div class="avatar-placeholder" style={`background:${avatarColor};width:48px;height:48px;`}>
            {displayAvatar === 'auto' ? avatarLetter : displayAvatar}
          </div>
        )}
      </a>
      <a href={`/user/${post.data.handle}`} class="post-author-info">
        <span class="post-author">{post.data.author}</span>
        <span class="post-handle">@{post.data.handle}</span>
      </a>
    </div>

    <PostAbstract content={post.data.abstract} wrapperClass="post-text post-abstract" />

    <div class="post-text">
      <Content />
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="post-tags" style="margin: 12px 0;">
        {post.data.tags.map((tag: string) => (
          <a href={`/tag/${encodeURIComponent(tag)}`} class="tag">#{tag}</a>
        ))}
      </div>
    )}

    {currentSeries && seriesPosts.length > 0 && (
      <section class="post-series">
        <div class="series-header">
          <div>
            <div class="series-label">系列文章</div>
            <div class="series-title">{currentSeries.name}</div>
          </div>
          <span class="series-id">{currentSeries.id}</span>
        </div>

        <div class="series-list">
          {seriesPosts.map((seriesPost) => (
            <div
              class="series-item"
              onclick={`location.href='/post/${seriesPost.id}'`}
            >
              <PostAbstract
                content={seriesPost.data.abstract}
                wrapperClass="series-item-title post-text"
                stopLinkPropagation={true}
              />
              <time class="series-item-meta full-date" datetime={seriesPost.data.date}></time>
            </div>
          ))}
        </div>
      </section>
    )}

    <div class="post-timestamp">
      <time class="full-date" datetime={post.data.date}></time>
    </div>
  </article>
</BaseLayout>

<script>
  function formatFullDate(dateStr: string) {
    const d = new Date(dateStr);
    const hours = d.getHours().toString().padStart(2, '0');
    const mins = d.getMinutes().toString().padStart(2, '0');
    return `${hours}:${mins} · ${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
  }

  document.querySelectorAll<HTMLTimeElement>('time.full-date[datetime]').forEach((el) => {
    el.textContent = formatFullDate(el.getAttribute('datetime')!);
  });
</script>

<style>
  .post-avatar {
    display: block;
    border-radius: 50%;
    transition: opacity 0.2s;
  }
  .post-avatar:hover {
    opacity: 0.85;
  }
  .post-author-info {
    display: flex;
    flex-direction: column;
  }
  .post-author-info:hover .post-author {
    text-decoration: underline;
  }
</style>
