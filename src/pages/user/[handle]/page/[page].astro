---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const PER_PAGE = 5;

export async function getStaticPaths() {
  const PER_PAGE = 5;
  const posts = await getCollection('posts');
  const users = await getCollection('users');
  const handleCounts = new Map<string, number>();

  posts.forEach((post) => {
    const h = post.data.handle;
    handleCounts.set(h, (handleCounts.get(h) ?? 0) + 1);
  });

  const paths: { params: { handle: string; page: string }; props: { userProfile: any } }[] = [];
  for (const [handle, count] of handleCounts.entries()) {
    const totalPages = Math.max(1, Math.ceil(count / PER_PAGE));
    const userProfile = users.find((u) => u.data.handle === handle);
    for (let page = 2; page <= totalPages; page += 1) {
      paths.push({
        params: { handle, page: String(page) },
        props: { userProfile: userProfile?.data ?? null },
      });
    }
  }

  return paths;
}

const { userProfile } = Astro.props;
const handle = Astro.params.handle;
const page = Number(Astro.params.page) || 2;

const posts = await getCollection('posts');
const userPosts = posts
  .filter((p) => p.data.handle === handle)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postData = userPosts[0]?.data;

const displayName = userProfile?.name || postData?.author || handle;
const displayAvatar = userProfile?.avatar || postData?.avatar || 'auto';
const bio = userProfile?.bio || '用 Markdown 記錄生活，分享技術與想法';
const joinDate = userProfile?.joinDate || '2024-01';
const location = userProfile?.location;
const website = userProfile?.website;
const bannerStyle = userProfile?.bannerColor
  ? `background:${userProfile.bannerColor}`
  : 'background:linear-gradient(135deg, #1d9bf0, #1a1a2e)';

const avatarColors = ['#1d9bf0', '#f91880', '#00ba7c', '#ffd400', '#7856ff', '#f97316'];
const colorIndex = displayName.charCodeAt(0) % avatarColors.length;
const avatarColor = avatarColors[colorIndex];
const avatarLetter = displayName.charAt(0).toUpperCase();

const totalPages = Math.max(1, Math.ceil(userPosts.length / PER_PAGE));
const currentPage = Math.min(Math.max(page, 1), totalPages);
const pagePosts = userPosts.slice((currentPage - 1) * PER_PAGE, currentPage * PER_PAGE);
const basePath = `/user/${handle}`;
const pagePath = (num: number) => (num === 1 ? basePath : `${basePath}/page/${num}`);

function formatJoinDate(dateStr: string) {
  const [year, month] = dateStr.split('-');
  return `${year}年${parseInt(month)}月`;
}

function getPaginationItems(totalPages: number, currentPage: number) {
  const pages: { type: string; number?: number }[] = [];
  const maxVisible = 7;

  if (totalPages <= maxVisible) {
    for (let i = 1; i <= totalPages; i += 1) {
      pages.push({ type: 'page', number: i });
    }
    return pages;
  }

  pages.push({ type: 'page', number: 1 });
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(totalPages - 1, currentPage + 1);

  if (start > 2) pages.push({ type: 'dots' });
  for (let i = start; i <= end; i += 1) {
    pages.push({ type: 'page', number: i });
  }
  if (end < totalPages - 1) pages.push({ type: 'dots' });
  pages.push({ type: 'page', number: totalPages });
  return pages;
}

const paginationItems = getPaginationItems(totalPages, currentPage);
---

<BaseLayout title={`${displayName} (@${handle}) 第 ${currentPage} 頁 / Social`}>
  <div class="page-header">
    <div class="back-btn">
      <a href="/" class="back-arrow" onclick="history.length > 1 ? history.back() : null; return false;">
        <i class="ti ti-arrow-left"></i>
      </a>
      <div>
        <h1>{displayName}</h1>
        <div class="subtitle">{userPosts.length} 則貼文</div>
      </div>
    </div>
  </div>

  <div class="profile-banner" style={bannerStyle}></div>

  <div class="profile-header">
    <div class="profile-avatar">
      <div class="avatar-placeholder" style={`background:${avatarColor}`}>
        {displayAvatar === 'auto' ? avatarLetter : displayAvatar}
      </div>
    </div>
    <div class="profile-name">{displayName}</div>
    <div class="profile-handle-text">@{handle}</div>
    <div class="profile-bio">{bio}</div>
    <div class="profile-meta">
      {location && (
        <span><i class="ti ti-map-pin"></i> {location}</span>
      )}
      {website && (
        <a href={website} target="_blank" rel="noopener noreferrer" class="profile-link">
          <i class="ti ti-link"></i> {website.replace(/^https?:\/\//, '')}
        </a>
      )}
      <span><i class="ti ti-calendar"></i> {formatJoinDate(joinDate)} 加入</span>
    </div>
  </div>

  {pagePosts.map((post: any) => (
    <PostCard
      id={post.id}
      author={post.data.author}
      handle={post.data.handle}
      avatar={post.data.avatar}
      abstract={post.data.abstract}
      date={post.data.date}
      tags={post.data.tags}
      hasContent={!!post.body?.trim()}
    />
  ))}

  {totalPages > 1 && (
    <div class="pagination">
      {currentPage > 1 && (
        <a href={pagePath(currentPage - 1)} class="pagination-link">上一頁</a>
      )}
      {paginationItems.map((item) =>
        item.type === 'dots' ? (
          <span class="pagination-dots">…</span>
        ) : (
          <a
            href={pagePath(item.number!)}
            class:list={['pagination-link', { active: item.number === currentPage }]}
          >
            {item.number}
          </a>
        )
      )}
      {currentPage < totalPages && (
        <a href={pagePath(currentPage + 1)} class="pagination-link">下一頁</a>
      )}
    </div>
  )}
</BaseLayout>

<style>
  .profile-link {
    color: var(--accent);
    transition: text-decoration 0.2s;
  }
  .profile-link:hover {
    text-decoration: underline;
  }
</style>
