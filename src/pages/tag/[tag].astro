---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TagPage from '../../components/TagPage.astro';
import { POSTS_PER_PAGE } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tagSet = new Set<string>();

  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => tagSet.add(tag));
  });

  return Array.from(tagSet).map((tag) => ({ params: { tag } }));
}

const posts = await getCollection('posts');
const tag = Astro.params.tag;
const filteredPosts = posts
  .filter((post) => post.data.tags?.includes(tag))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const postCount = filteredPosts.length;
const currentPage = 1;
const totalPages = Math.max(1, Math.ceil(postCount / POSTS_PER_PAGE));
const pagePosts = filteredPosts.slice(0, POSTS_PER_PAGE);
const encodedTag = encodeURIComponent(tag);
const basePath = `/tag/${encodedTag}`;
---

<BaseLayout title={`#${tag} / Social`}>
  <TagPage
    tag={tag}
    basePath={basePath}
    currentPage={currentPage}
    totalPages={totalPages}
    pagePosts={pagePosts}
    postCount={postCount}
  />
</BaseLayout>
