---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));

  return Array.from({ length: totalPages }, (_, index) => ({
    params: { page: String(index + 1) },
  }));
}

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const totalPages = Math.max(1, Math.ceil(sortedPosts.length / POSTS_PER_PAGE));
const page = Number(Astro.params.page) || 1;
const currentPage = Math.min(Math.max(page, 1), totalPages);
const pagePosts = sortedPosts.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);
const pagePath = (num: number) => (num === 1 ? '/' : `/page/${num}`);

function getPaginationItems(totalPages: number, currentPage: number) {
  const pages = [];
  const maxVisible = 7;

  if (totalPages <= maxVisible) {
    for (let i = 1; i <= totalPages; i += 1) {
      pages.push({ type: 'page', number: i });
    }
    return pages;
  }

  pages.push({ type: 'page', number: 1 });
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(totalPages - 1, currentPage + 1);

  if (start > 2) pages.push({ type: 'dots' });

  for (let i = start; i <= end; i += 1) {
    pages.push({ type: 'page', number: i });
  }

  if (end < totalPages - 1) pages.push({ type: 'dots' });

  pages.push({ type: 'page', number: totalPages });
  return pages;
}

const paginationItems = getPaginationItems(totalPages, currentPage);
---

<BaseLayout title={`首頁第 ${currentPage} 頁 / Social`}>
  <div class="page-header">
    <h1>首頁</h1>
    <p class="subtitle">第 {currentPage} 頁，共 {totalPages} 頁</p>
  </div>

  <div class="tabs">
    <a href="/" class="tab active">依時間排序</a>
    <a href="/random" class="tab">隨機推薦</a>
  </div>

  {pagePosts.map((post) => (
    <PostCard
      id={post.id}
      author={post.data.author}
      handle={post.data.handle}
      avatar={post.data.avatar}
      abstract={post.data.abstract}
      date={post.data.date}
      tags={post.data.tags}
      hasContent={!!post.body?.trim()}
    />
  ))}

  {totalPages > 1 && (
    <div class="pagination">
      {currentPage > 1 && (
        <a href={pagePath(currentPage - 1)} class="pagination-link">上一頁</a>
      )}
      {paginationItems.map((item) =>
        item.type === 'dots' ? (
          <span class="pagination-dots">…</span>
        ) : (
          <a
            href={pagePath(item.number)}
            class:list={['pagination-link', { active: item.number === currentPage }]}
          >
            {item.number}
          </a>
        )
      )}
      {currentPage < totalPages && (
        <a href={pagePath(currentPage + 1)} class="pagination-link">下一頁</a>
      )}
    </div>
  )}
</BaseLayout>
